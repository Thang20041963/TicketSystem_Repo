<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="Ticket_System_App.Views.HomeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:helpers="clr-namespace:Ticket_System_App.Helpers"
        Title="Ticket System"
        Height="680" Width="1100"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        MinHeight="500" MinWidth="800">

    <Window.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="14,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bg" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bg" Property="Background" Value="#313244"/>
                                <Setter Property="Foreground" Value="#CDD6F4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border CornerRadius="12" Background="#1E1E2E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="Black"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Title bar -->
            <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#181825"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel LastChildFill="False" VerticalAlignment="Center">
                    <TextBlock Text="🎫 Ticket System" Foreground="#CDD6F4"
                               FontSize="14" FontWeight="SemiBold"
                               Margin="16,0,0,0" VerticalAlignment="Center"/>
                    <Button DockPanel.Dock="Right" Content="✕" Width="30" Height="30"
                            Margin="0,0,8,0" Click="CloseButton_Click" Cursor="Hand"
                            Background="Transparent" BorderThickness="0" Foreground="#888">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="closeBg" Background="{TemplateBinding Background}"
                                        CornerRadius="15">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="closeBg" Property="Background" Value="#E81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </DockPanel>
            </Border>

            <!-- Sidebar -->
            <Border Grid.Row="1" Grid.Column="0" Background="#181825">
                <DockPanel LastChildFill="False">
                    <!-- User info -->
                    <Border DockPanel.Dock="Top" Padding="16,20,16,16"
                            BorderBrush="#313244" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <Border Width="48" Height="48" CornerRadius="24"
                                    HorizontalAlignment="Left" Margin="0,0,0,10">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#89B4FA" Offset="0"/>
                                        <GradientStop Color="#B4BEFE" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="👤" FontSize="22"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="{Binding WelcomeText}"
                                       Foreground="#CDD6F4" FontWeight="SemiBold" FontSize="13"
                                       TextTrimming="CharacterEllipsis"/>
                            <Border CornerRadius="4" Padding="6,2" Margin="0,4,0,0"
                                    Background="#313244" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding RoleBadge}"
                                           Foreground="#89B4FA" FontSize="11" FontWeight="Medium"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Nav buttons -->
                    <StackPanel DockPanel.Dock="Top" Margin="10,12,10,0">
                        <Button x:Name="BtnMyTickets" Content="📋  My Tickets"
                                Visibility="{Binding IsEmployee, Converter={StaticResource BoolToVis}}"
                                Click="NavMyTickets_Click"
                                Style="{StaticResource NavButtonStyle}"/>

                        <Button x:Name="BtnAllTickets" Content="📋  All Tickets"
                                Visibility="{Binding IsAdminOrSupporter, Converter={StaticResource BoolToVis}}"
                                Click="NavAllTickets_Click"
                                Style="{StaticResource NavButtonStyle}"/>

                        <Button x:Name="BtnAddTicket" Content="➕  Tạo Ticket"
                                Visibility="{Binding IsEmployee, Converter={StaticResource BoolToVis}}"
                                Click="NavAddTicket_Click"
                                Style="{StaticResource NavButtonStyle}"/>
                    </StackPanel>

                    <!-- Logout at bottom -->
                    <Button DockPanel.Dock="Bottom" Content="🚪  Đăng xuất"
                            Command="{Binding LogoutCommand}"
                            Margin="10,0,10,16"
                            Foreground="#F38BA8"
                            Style="{StaticResource NavButtonStyle}"/>
                </DockPanel>
            </Border>

            <!-- Main content frame -->
            <Border Grid.Row="1" Grid.Column="1" Background="#1E1E2E" CornerRadius="0,0,12,0">
                <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
            </Border>
        </Grid>
    </Border>
</Window>
