<Window x:Class="Ticket_System_App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ticket System - Đăng nhập" 
        Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border CornerRadius="16" Background="#1E1E2E">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.5" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Title Bar (draggable) -->
            <Grid Grid.Row="0" Height="36" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Button Content="✕" 
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Width="28" Height="28"
                        Click="CloseButton_Click"
                        Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#888"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E81123"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </Grid>

            <!-- Login Form -->
            <StackPanel Grid.Row="1" Margin="40,10,40,40" VerticalAlignment="Center">

                <!-- Logo / Title -->
                <TextBlock Text="🎫" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Ticket System" 
                           FontSize="26" FontWeight="Bold" 
                           Foreground="#CDD6F4"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="Đăng nhập vào tài khoản của bạn" 
                           FontSize="13" 
                           Foreground="#6C7086"
                           HorizontalAlignment="Center" 
                           Margin="0,4,0,30"/>

                <!-- Username -->
                <TextBlock Text="Tên đăng nhập" Foreground="#A6ADC8" FontSize="13" Margin="0,0,0,6"/>
                <Border Background="#313244" CornerRadius="8" Padding="12,10">
                    <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" 
                             Background="Transparent" 
                             Foreground="#CDD6F4" 
                             BorderThickness="0" 
                             FontSize="14"
                             CaretBrush="#89B4FA"
                             x:Name="UsernameTextBox"/>
                </Border>

                <!-- Password -->
                <TextBlock Text="Mật khẩu" Foreground="#A6ADC8" FontSize="13" Margin="0,16,0,6"/>
                <Border Background="#313244" CornerRadius="8" Padding="12,10">
                    <PasswordBox x:Name="PasswordBox" 
                                 Background="Transparent" 
                                 Foreground="#CDD6F4" 
                                 BorderThickness="0" 
                                 FontSize="14"
                                 CaretBrush="#89B4FA"
                                 PasswordChanged="PasswordBox_PasswordChanged"/>
                </Border>

                <!-- Error Message -->
                <TextBlock Text="{Binding ErrorMessage}" 
                           Foreground="#F38BA8" 
                           FontSize="12" 
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

                <!-- Login Button -->
                <Button Command="{Binding LoginCommand}" 
                        Margin="0,24,0,0" Height="42"
                        Cursor="Hand"
                        IsDefault="True">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="btnBorder" CornerRadius="8" Padding="0,10">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#89B4FA" Offset="0"/>
                                                    <GradientStop Color="#B4BEFE" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="btnBorder" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <!-- Loading spinner or text -->
                        <TextBlock Text="⏳" FontSize="14" Margin="0,0,6,0"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="#1E1E2E">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Đăng nhập"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Text" Value="Đang xử lý..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

            </StackPanel>
        </Grid>
    </Border>
</Window>
