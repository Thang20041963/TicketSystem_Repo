<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ticket_System_App.Views.Pages.TicketDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Ticket_System_App.Helpers"
      Title="Chi tiết Ticket"
      Background="#1E1E2E">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
    </Page.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Back + Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="← Quay lại" Click="BackButton_Click" Cursor="Hand"
                    Background="Transparent" Foreground="#89B4FA"
                    BorderThickness="0" FontSize="13" Margin="0,0,16,0"/>
            <TextBlock Text="{Binding Ticket.Title, StringFormat='#{0}', FallbackValue='...'}"
                       FontSize="18" FontWeight="Bold" Foreground="#CDD6F4"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Ticket meta -->
        <Border Grid.Row="1" Background="#252535" CornerRadius="10" Padding="20,14" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding Ticket.Title}" Foreground="#CDD6F4"
                               FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding Ticket.Description}" Foreground="#A6ADC8"
                               FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"
                               Visibility="{Binding Ticket.Description, Converter={StaticResource StrToVis}}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="Người tạo: " Foreground="#6C7086" FontSize="12"/>
                        <TextBlock Text="{Binding Ticket.CreatorName}" Foreground="#CDD6F4" FontSize="12"/>
                        <TextBlock Text="  |  Assignee: " Foreground="#6C7086" FontSize="12"/>
                        <TextBlock Text="{Binding Ticket.AssigneeName, TargetNullValue='Chưa gán'}"
                                   Foreground="#CDD6F4" FontSize="12"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Ticket.CreatedAt, StringFormat='Tạo: {0:dd/MM/yyyy HH:mm}'}"
                                   Foreground="#6C7086" FontSize="11"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <!-- Status chip -->
                    <Border CornerRadius="6" Padding="12,5" HorizontalAlignment="Center">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#313244"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Ticket.Status}" Value="OPEN">
                                        <Setter Property="Background" Value="#1E3A5F"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Ticket.Status}" Value="IN_PROGRESS">
                                        <Setter Property="Background" Value="#3D2B00"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Ticket.Status}" Value="RESOLVED">
                                        <Setter Property="Background" Value="#1A3A1A"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Ticket.Status}" Value="CLOSED">
                                        <Setter Property="Background" Value="#2A1A2A"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding Ticket.Status}" FontSize="13" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#A6ADC8"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Ticket.Status}" Value="OPEN">
                                            <Setter Property="Foreground" Value="#89B4FA"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Ticket.Status}" Value="IN_PROGRESS">
                                            <Setter Property="Foreground" Value="#F9E2AF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Ticket.Status}" Value="RESOLVED">
                                            <Setter Property="Foreground" Value="#A6E3A1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Ticket.Status}" Value="CLOSED">
                                            <Setter Property="Foreground" Value="#CBA6F7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <TextBlock Text="{Binding Ticket.Priority}" Foreground="#FAB387"
                               FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                </StackPanel>

                <!-- Update status (SUPPORTER/ADMIN) -->
                <StackPanel Grid.Column="2" VerticalAlignment="Center"
                            Visibility="{Binding IsAdminOrSupporter, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="Cập nhật trạng thái" Foreground="#A6ADC8"
                               FontSize="11" Margin="0,0,0,6"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}"
                              SelectedItem="{Binding SelectedStatus}"
                              Background="#313244" Foreground="#CDD6F4"
                              BorderBrush="#45475A" MinWidth="130"/>
                    <Button Content="Cập nhật" Command="{Binding UpdateStatusCommand}"
                            Margin="0,8,0,0" Padding="10,6" Cursor="Hand"
                            Background="#89B4FA" Foreground="#1E1E2E"
                            BorderThickness="0" FontWeight="SemiBold">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Tabs: Comments + History -->
        <TabControl Grid.Row="2" Background="#1E1E2E" BorderBrush="#313244">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Foreground" Value="#A6ADC8"/>
                    <Setter Property="Padding" Value="16,8"/>
                    <Setter Property="BorderThickness" Value="0"/>
                </Style>
            </TabControl.Resources>

            <!-- Comments Tab -->
            <TabItem Header="💬 Bình luận">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" Margin="0,8,0,8">
                        <ItemsControl ItemsSource="{Binding Comments}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#252535" CornerRadius="8"
                                            Padding="14,10" Margin="0,4">
                                        <StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding UserName}"
                                                           Foreground="#89B4FA" FontWeight="SemiBold" FontSize="12"/>
                                                <TextBlock Text="{Binding CreatedAt, StringFormat='  •  {0:dd/MM HH:mm}'}"
                                                           Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Content}" Foreground="#CDD6F4"
                                                       FontSize="13" Margin="0,6,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Add comment -->
                    <Border Grid.Row="1" Background="#252535" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding NewComment, UpdateSourceTrigger=PropertyChanged}"
                                     Background="Transparent" Foreground="#CDD6F4"
                                     BorderThickness="0" FontSize="13" CaretBrush="#89B4FA"
                                     VerticalContentAlignment="Center"
                                     TextWrapping="Wrap" AcceptsReturn="False"
                                     Margin="4,0"/>
                            <Button Grid.Column="1" Content="Gửi  ▶"
                                    Command="{Binding AddCommentCommand}"
                                    Cursor="Hand" Padding="14,8"
                                    Background="#89B4FA" Foreground="#1E1E2E"
                                    BorderThickness="0" FontWeight="SemiBold">
                                <Button.Resources>
                                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Status History Tab -->
            <TabItem Header="📜 Lịch sử trạng thái">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
                    <ItemsControl ItemsSource="{Binding StatusHistories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="#252535" CornerRadius="8" Padding="14,10" Margin="0,4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding OldStatus}" Foreground="#6C7086"
                                                           FontSize="12" FontWeight="Medium"/>
                                                <TextBlock Text=" → " Foreground="#A6ADC8" FontSize="12"/>
                                                <TextBlock Text="{Binding NewStatus}" Foreground="#A6E3A1"
                                                           FontSize="12" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Text="{Binding ChangedByUserName, StringFormat='Bởi {0}'}"
                                                       Foreground="#89B4FA" FontSize="11" Margin="0,4,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding ChangedAt, StringFormat='{}{0:dd/MM/yyyy HH:mm}'}"
                                                   Foreground="#6C7086" FontSize="11" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status / error message -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#A6E3A1" FontSize="12" Margin="0,8,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
    </Grid>
</Page>
