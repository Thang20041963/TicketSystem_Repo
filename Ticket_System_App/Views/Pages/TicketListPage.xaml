<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ticket_System_App.Views.Pages.TicketListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Ticket_System_App.Helpers"
      Title="Danh sách Ticket"
      Background="#1E1E2E">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>

        <Style x:Key="FilterCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="MinWidth" Value="120"/>
        </Style>

        <Style x:Key="ChipBase" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,3"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📋" FontSize="22" VerticalAlignment="Center" Margin="0,0,10,0"/>
            <TextBlock Text="Danh sách Ticket"
                       FontSize="20" FontWeight="Bold" Foreground="#CDD6F4"
                       VerticalAlignment="Center"/>
            <Button Content="🔄 Làm mới"
                    Command="{Binding RefreshCommand}"
                    Margin="20,0,0,0"
                    Cursor="Hand"
                    Padding="12,6"
                    Background="#313244" Foreground="#89B4FA"
                    BorderBrush="#45475A" BorderThickness="1">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="6"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Filter bar (SUPPORTER/ADMIN only) -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,16"
                    Visibility="{Binding IsAdminOrSupporter, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="Trạng thái:" Foreground="#A6ADC8" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding FilterStatus}"
                      Style="{StaticResource FilterCombo}"/>

            <TextBlock Text="Độ ưu tiên:" Foreground="#A6ADC8" VerticalAlignment="Center" Margin="16,0,8,0"/>
            <ComboBox ItemsSource="{Binding PriorityOptions}"
                      SelectedItem="{Binding FilterPriority}"
                      Style="{StaticResource FilterCombo}"/>

            <Button Content="Lọc" Command="{Binding FilterCommand}"
                    Margin="12,0,0,0" Padding="14,6" Cursor="Hand"
                    Background="#89B4FA" Foreground="#1E1E2E"
                    BorderThickness="0" FontWeight="SemiBold">
                <Button.Resources>
                    <Style TargetType="Border"><Setter Property="CornerRadius" Value="6"/></Style>
                </Button.Resources>
            </Button>
        </StackPanel>

        <!-- Loading indicator -->
        <TextBlock Grid.Row="2" Text="⏳ Đang tải..."
                   Foreground="#89B4FA" FontSize="14"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>

        <!-- Ticket list -->
        <ListView Grid.Row="2" ItemsSource="{Binding Tickets}"
                  Background="Transparent" BorderThickness="0"
                  SelectionChanged="ListView_SelectionChanged"
                  Visibility="{Binding IsNotLoading, Converter={StaticResource BoolToVis}}"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Margin" Value="0,3"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A2A3E"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Background="#252535" CornerRadius="8" Padding="16,12" Margin="0,2">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="{Binding Id, StringFormat='#{0}'}"
                                       Foreground="#6C7086" FontSize="12" VerticalAlignment="Center"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Title}" Foreground="#CDD6F4"
                                           FontWeight="Medium" FontSize="13"/>
                                <TextBlock Text="{Binding CreatorName, StringFormat='by {0}'}"
                                           Foreground="#6C7086" FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Status chip -->
                            <Border Grid.Column="2" CornerRadius="4" Padding="8,3"
                                    VerticalAlignment="Center" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#313244"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="OPEN">
                                                <Setter Property="Background" Value="#1E3A5F"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="IN_PROGRESS">
                                                <Setter Property="Background" Value="#3D2B00"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="RESOLVED">
                                                <Setter Property="Background" Value="#1A3A1A"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="CLOSED">
                                                <Setter Property="Background" Value="#2A1A2A"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Medium">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#A6ADC8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="OPEN">
                                                    <Setter Property="Foreground" Value="#89B4FA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="IN_PROGRESS">
                                                    <Setter Property="Foreground" Value="#F9E2AF"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="RESOLVED">
                                                    <Setter Property="Foreground" Value="#A6E3A1"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="CLOSED">
                                                    <Setter Property="Foreground" Value="#CBA6F7"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>

                            <!-- Priority -->
                            <TextBlock Grid.Column="3" Text="{Binding Priority}"
                                       Foreground="#FAB387" FontSize="11"
                                       VerticalAlignment="Center"/>

                            <!-- Assignee -->
                            <TextBlock Grid.Column="4" Text="{Binding AssigneeName, TargetNullValue='Chưa gán'}"
                                       Foreground="#6C7086" FontSize="11"
                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                            <!-- Date -->
                            <TextBlock Grid.Column="5"
                                       Text="{Binding CreatedAt, StringFormat='{}{0:dd/MM/yyyy}'}"
                                       Foreground="#6C7086" FontSize="11"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- Status message -->
        <TextBlock Grid.Row="3" Text="{Binding StatusMessage}"
                   Foreground="#F38BA8" FontSize="12" Margin="0,10,0,0"
                   Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
    </Grid>
</Page>
