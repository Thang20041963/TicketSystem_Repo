<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="Ticket_System_App.Views.Pages.AddTicketPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:helpers="clr-namespace:Ticket_System_App.Helpers"
      Title="Tạo Ticket mới"
      Background="#1E1E2E">

    <Page.Resources>
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <helpers:StringToVisibilityConverter x:Key="StrToVis"/>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,10"/>
        </Style>
    </Page.Resources>

    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="➕ Tạo Ticket mới"
                   FontSize="20" FontWeight="Bold" Foreground="#CDD6F4" Margin="0,0,0,24"/>

        <!-- Form -->
        <Border Grid.Row="1" Background="#252535" CornerRadius="10" Padding="28,24" MaxWidth="600"
                HorizontalAlignment="Left">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Tiêu đề *" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16">
                    <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" Foreground="#CDD6F4"
                             BorderThickness="0" FontSize="14" CaretBrush="#89B4FA"/>
                </Border>

                <!-- Description -->
                <TextBlock Text="Mô tả (tùy chọn)" Style="{StaticResource FieldLabel}"/>
                <Border Style="{StaticResource InputBorder}" Margin="0,0,0,16" Height="100">
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent" Foreground="#CDD6F4"
                             BorderThickness="0" FontSize="13" CaretBrush="#89B4FA"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalAlignment="Top"/>
                </Border>

                <!-- Priority -->
                <TextBlock Text="Độ ưu tiên" Style="{StaticResource FieldLabel}"/>
                <ComboBox ItemsSource="{Binding Priorities}"
                          SelectedItem="{Binding SelectedPriority}"
                          Background="#313244" Foreground="#CDD6F4"
                          BorderBrush="#45475A" BorderThickness="1"
                          Padding="10,8" Margin="0,0,0,24"
                          FontSize="13"/>

                <!-- Submit button -->
                <Button Command="{Binding SubmitCommand}"
                        Height="44" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bg" CornerRadius="8">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#89B4FA" Offset="0"/>
                                                    <GradientStop Color="#B4BEFE" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.85"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter TargetName="bg" Property="Opacity" Value="0.5"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳ " Foreground="#1E1E2E"
                                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Foreground="#1E1E2E" FontSize="15" FontWeight="SemiBold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✅ Tạo Ticket"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Text" Value="Đang tạo..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button>

                <!-- Status feedback -->
                <TextBlock Text="{Binding StatusMessage}"
                           Foreground="#A6E3A1" FontSize="13" Margin="0,14,0,0"
                           TextWrapping="Wrap"
                           Visibility="{Binding StatusMessage, Converter={StaticResource StrToVis}}"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
